{
  "name": "mermaid-gantt-editor",
  "displayName": "Mermaid Gantt Editor",
  "publisher": "yyamamot",
  "description": "Edit Mermaid Gantt diagrams with a lossless AST-backed Task Grid",
  "version": "0.0.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yyamamot/mermaid-gantt-editor.git"
  },
  "bugs": {
    "url": "https://github.com/yyamamot/mermaid-gantt-editor/issues"
  },
  "homepage": "https://github.com/yyamamot/mermaid-gantt-editor#readme",
  "icon": "assets/icon.png",
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "mermaid",
    "gantt",
    "markdown",
    "task-grid"
  ],
  "packageManager": "pnpm@10.30.3",
  "type": "commonjs",
  "engines": {
    "vscode": "^1.105.0",
    "node": ">=22.0.0"
  },
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "activationEvents": [
    "onCommand:mermaidGantt.showParserInfo",
    "onCommand:mermaidGantt.openTaskGrid",
    "onLanguage:markdown",
    "onLanguage:mermaid"
  ],
  "contributes": {
    "languages": [
      {
        "id": "mermaid",
        "aliases": [
          "Mermaid",
          "mermaid"
        ],
        "extensions": [
          ".mmd",
          ".mermaid"
        ]
      }
    ],
    "commands": [
      {
        "command": "mermaidGantt.showParserInfo",
        "title": "%command.mermaidGantt.showParserInfo.title%"
      },
      {
        "command": "mermaidGantt.openTaskGrid",
        "title": "%command.mermaidGantt.openTaskGrid.title%"
      }
    ]
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "node -e \"console.log('lint stub: no linter configured yet')\"",
    "format": "node -e \"console.log('format stub: no formatter configured yet')\"",
    "build": "node ./scripts/build.mjs",
    "build:test": "tsc -p tsconfig.json",
    "dev:vscode": "node ./scripts/open-clean-vscode.mjs",
    "package:vsix": "node ./scripts/vsix.mjs package",
    "test:package": "node ./scripts/vsix.mjs smoke",
    "install:vsix": "node ./scripts/vsix.mjs install",
    "uninstall:vsix": "node ./scripts/vsix.mjs uninstall",
    "test:unit": "vitest run --dir test/unit",
    "test:integration": "vitest run --dir test/integration",
    "test:integration:host": "pnpm run build && pnpm run build:test && node ./out/test/integration-host/run.js",
    "test:nightly:visual": "node ./scripts/nightly-visual.mjs",
    "review:ui:llm": "node ./scripts/review-ui-llm.mjs",
    "review:ui:llm:scenario": "node ./scripts/review-ui-llm.mjs --single",
    "review:ui:feature": "node ./scripts/review-ui-feature.mjs",
    "verify:ui-change": "node ./scripts/verify-ui-change.mjs",
    "perf:large-gantt": "node ./scripts/perf-large-gantt.mjs",
    "check:l10n": "node ./scripts/check-l10n.mjs",
    "check:mermaid-compat": "pnpm run build:test && node ./out/test/compatibility/mermaid-runtime.js",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run test:unit",
    "verify": "pnpm run build && pnpm run check:l10n && pnpm run test:unit && pnpm run test:integration && pnpm run test:integration:host"
  },
  "files": [
    "assets/**",
    "dist/**",
    "l10n/**",
    "package.nls.json",
    "package.nls.ja.json",
    "README.md",
    "README.ja.md",
    "CHANGELOG.md",
    "LICENSE",
    "package.json"
  ],
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/vscode": "^1.105.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.2",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "mermaid": "11.14.0"
  }
}
